# Cell 1
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from config import DATA_RAW, COLUMN_NAMES
data = pd.read_csv(DATA_RAW, header=None, names=COLUMN_NAMES)
print(data.shape)
print(data.iloc[:, -1].value_counts(normalize=True))  # ~39% spam[web:14]

# Cell 2
plt.figure(figsize=(12, 4))
plt.subplot(1, 2, 1)
sns.countplot(x=data.iloc[:, -1])
plt.title('Spam vs Ham Distribution')
plt.subplot(1, 2, 2)
data.iloc[:, :-1].hist(figsize=(20, 20), bins=50)
plt.suptitle('Feature Distributions')
plt.tight_layout()
plt.savefig('../data/eda_plots.png')
